{
	"name": "data-structures",
	"version": "0.1.0",
	"repository": "git+https://github.com/StimulCross/data-structures.git",
	"author": "Stimul Cross <stimulcross@gmail.com>",
	"license": "MIT",
	"description": "",
	"private": true,
	"packageManager": "pnpm@10.30.3",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "turbo run build",
		"rebuild": "turbo run rebuild",
		"clean": "turbo run clean",
		"lint": "turbo run lint",
		"lint:fix": "eslint . --fix",
		"format:check": "prettier --config \"prettier.config.cjs\" --check packages libs",
		"format:fix": "prettier --config \"prettier.config.cjs\" --write packages libs",
		"check-types": "turbo run check-types",
		"prepare": "husky",
		"preversion": "pnpm run rebuild && pnpm run format:check && pnpm run lint",
		"postversion": "pnpm i",
		"prepublishOnly": "pnpm run rebuild && pnpm run format:check && pnpm run lint",
		"test": "vitest run",
		"test:verbose": "vitest --run --reporter verbose --logHeapUsage",
		"test:cov": "vitest run --coverage",
		"test:cov:verbose": "vitest --run --coverage --reporter verbose --logHeapUsage",
		"eslint-configs": "pnpm --filter=eslint-config",
		"typescript-config": "pnpm --filter=typescript-config",
		"deque": "pnpm --filter=@stimulcross/ds-deque",
		"binary-heap": "pnpm --filter=@stimulcross/ds-binary-heap",
		"doubly-linked-list": "pnpm --filter=@stimulcross/ds-doubly-linked-list",
		"queue": "pnpm --filter=@stimulcross/ds-queue",
		"policy-priority-queue": "pnpm --filter=@stimulcross/ds-policy-priority-queue"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.2",
		"@stimulcross/commitlint-config": "^2.0.0",
		"@stimulcross/eslint-config-base": "^2.0.0",
		"@stimulcross/eslint-config-node": "^2.0.0",
		"@stimulcross/eslint-config-typescript": "^2.0.0",
		"@stimulcross/prettier-config": "^2.0.0",
		"@types/node": "^25.3.0",
		"@vitest/coverage-v8": "^4.0.18",
		"del-cli": "^7.0.0",
		"eslint": "^9.39.3",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"lerna": "^9.0.4",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"turbo": "^2.8.10",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
