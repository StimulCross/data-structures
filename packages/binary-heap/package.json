{
	"name": "@stimulcross/ds-binary-heap",
	"version": "0.1.0",
	"description": "Binary Heap implementation for TypeScript.",
	"keywords": [
		"binary-heap",
		"data-structure",
		"heap"
	],
	"author": "StimulCross <stimulcross@gmail.com>",
	"license": "MIT",
	"homepage": "https://github.com/StimulCross/data-structures/tree/main/packages/binary-heap#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/StimulCross/data-structures.git",
		"directory": "packages/binary-heap"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		}
	},
	"packageManager": "pnpm@10.28.0",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"rebuild": "pnpm run clean && pnpm run build",
		"clean": "del-cli lib *.tsbuildinfo",
		"lint": "eslint src tests",
		"lint:fix": "eslint src tests --fix",
		"format:check": "prettier --check src",
		"format:fix": "prettier --write src",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"preversion": "pnpm run rebuild && pnpm run format:check && pnpm run lint",
		"prepublishOnly": "pnpm run rebuild && pnpm run format:check && pnpm run lint"
	},
	"files": [
		"LICENSE",
		"README.md",
		"lib",
		"!lib/**/*.d.ts.map",
		"!lib/**/*.js.map"
	],
	"devDependencies": {
		"eslint-config": "workspace:*",
		"typescript-config": "workspace:*"
	}
}
